{
	"name": "obsidian-latex-suite",
	"version": "1.11.5",
	"description": "Make typesetting LaTeX math as fast as handwriting through snippets, text expansion, and editor enhancements",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "npm run lint && npm run build && node version-bump.mjs && git add manifest.json versions.json",
		"lint": "npm run tsc && npm run eslint",
		"tsc": "tsc --noEmit -skipLibCheck",
		"eslint": "eslint --fix",
		"wdio": "wdio run ./wdio.conf.mts",
		"test": "npm run test:build && npm run wdio",
		"test:build": "node esbuild.config.mjs test",
		"test:dev": "node esbuild.config.mjs test-dev"
	},
	"keywords": [],
	"author": "",
	"license": "MIT",
	"devDependencies": {
		"@codemirror/autocomplete": "^6.0.0",
		"@codemirror/commands": "^6.0.0",
		"@codemirror/lang-javascript": "^6.0.0",
		"@codemirror/language": "https://github.com/lishid/cm-language",
		"@codemirror/lint": "^6.0.0",
		"@codemirror/search": "^6.0.0",
		"@codemirror/state": "^6.0.0",
		"@codemirror/view": "^6.0.0",
		"@eslint/eslintrc": "^3.3.3",
		"@eslint/js": "^9.39.2",
		"@lezer/common": "^1.0.3",
		"@popperjs/core": "2.11.5",
		"@types/mocha": "^10.0.10",
		"@types/node": "^16.18.126",
		"@typescript-eslint/eslint-plugin": "^8.55.0",
		"@typescript-eslint/parser": "^8.55.0",
		"@wdio/cli": "^9.27.0",
		"@wdio/globals": "^9.27.0",
		"@wdio/local-runner": "^9.27.0",
		"@wdio/mocha-framework": "^9.27.0",
		"@wdio/spec-reporter": "^9.27.0",
		"@wdio/visual-service": "^9.2.2",
		"builtin-modules": "^3.2.0",
		"codemirror": "^6.0.0",
		"esbuild": "^0.20.2",
		"esbuild-plugin-inline-import": "^1.0.2",
		"eslint": "^9.39.2",
		"expect-webdriverio": "^5.6.5",
		"globals": "^17.3.0",
		"mocha": "^11.7.5",
		"obsidian": "^1.12.3",
		"puppeteer-core": "^24.42.0",
		"tslib": "2.3.1",
		"typescript": "^5.9.3",
		"wdio-obsidian-reporter": "^3.0.2",
		"wdio-obsidian-service": "^3.0.2"
	},
	"dependencies": {
		"valibot": "^1.3.1"
	}
}
